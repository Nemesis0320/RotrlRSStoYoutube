[0:v]scale=1200:1200,setsar=1[bg];
[1:a]showwaves=s=1200x200:mode=p2p:colors=white:scale=sqrt:draw=full,format=gray[wave_raw];
[wave_raw]scale=1200:600[wave_up];
[wave_up]scale=1200:300[wave_comp];
[wave_comp]boxblur=2:0[wave_smooth];
[wave_smooth]pad=1200:1200:0:(1200-ih)/2[wave_padded];
[wave_padded]geq=lum='between(((X-600)*(X-600))/(241*241)+((Y-555)*(Y-555))/(241*241),1+((lum((atan2(Y-555,X-600)+PI)/(2*PI)*(W-1),150)-128)/128)*1.5-0.05,1+((lum((atan2(Y-555,X-600)+PI)/(2*PI)*(W-1),150)-128)/128)*1.5+0.05)*255'[ring_base];
[ring_base]format=rgba,colorkey=black:0.01:0[ring_keyed];
[bg][ring_keyed]overlay=0:0[outv]
