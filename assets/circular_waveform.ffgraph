[0:v]scale=1200:1200,setsar=1[bg];

[1:a]showwaves=s=1200x300:mode=p2p:colors=white:scale=sqrt[wave_raw];
[wave_raw]boxblur=2:0[wave_smooth];
[wave_smooth]pad=1200:1200:0:(1200-ih)/2[wave_padded];

[wave_padded]geq=lum='px=X-600;py=Y-555;theta=-atan2(py,px);u=(theta+PI)/(2*PI);wx=u*(W-1);amp=(lum(wx,600)-128)/128;r=241+1.5*amp;dist=sqrt(px*px+py*py);between(dist,r-2,r+2)*255'[ring_raw];

[ring_raw]gblur=sigma=8[ring_glow];

[bg][ring_glow]overlay=0:0[outv]
