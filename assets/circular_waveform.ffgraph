[0:v]scale=1200:1200,setsar=1[bg];
[1:a]showwaves=s=1200x200:mode=line:colors=white:scale=sqrt:draw=full,format=gray[wave_raw];
[wave_raw]boxblur=2:1,scale=1200:1200:flags=lanczos[wave_smooth];
[wave_smooth]geq=lum='between(sqrt((X-600)*(X-600)+(Y-555)*(Y-555)),260,280)*lum((atan2(Y-555,X-600)+PI)/(2*PI)*(W-1),H/2)'[ring_base];
[ring_base]split=2[gold_src][clip_src];
[gold_src]geq=r='255':g='200':b='50':a='if(lum(X,Y)>0,200,0)'[gold_colored];
[clip_src]geq=r='255':g='0':b='0':a='if(lum(X,Y)>0.90*255,255,0)'[red_colored];
[gold_colored][red_colored]overlay=0:0:format=auto,boxblur=20:2[wave_final];
[bg][wave_final]overlay=0:0[outv];
