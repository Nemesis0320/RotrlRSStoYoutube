[0:v]scale=1200:1200,setsar=1[bg];
[1:a]showwaves=s=1200x200:mode=cline:colors=white:scale=sqrt:draw=full,format=gray[wave_raw];
[wave_raw]scale=1200:600[wave_up];
[wave_up]scale=1200:120[wave_comp];
[wave_comp]boxblur=20:0[wave_thick];
[wave_thick]pad=1200:1200:0:(1200-ih)/2[wave_padded];
[wave_padded]geq=lum='between(((X-600)*(X-600))/(222*222)+((Y-555)*(Y-555))/(260*260),1+((lum((atan2(Y-555,X-600)+PI)/(2*PI)*(W-1),600)-128)/128)*0.75-0.02,1+((lum((atan2(Y-555,X-600)+PI)/(2*PI)*(W-1),600)-128)/128)*0.75+0.02)*255'[ring_base];
[ring_base]format=rgba,colorkey=black:0.01:0[ring_keyed];
[bg][ring_keyed]overlay=0:0[outv]
