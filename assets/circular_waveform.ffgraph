[0:v]scale=1200:1200,setsar=1[bg];
[1:a]showwaves=s=1200x200:mode=line:colors=white:scale=sqrt:draw=full,format=gray[wave_raw];
[wave_raw]boxblur=0:40[wave_thick];
[wave_thick]pad=1200:1200:0:(1200-ih)/2[wave_padded];
[wave_padded]geq=lum='between(sqrt((X-600)*(X-600)+(Y-555)*(Y-555)),271.6,272.0)*24*lum((atan2(Y-555,X-600)+PI)/(2*PI)*(W-1),600)'[ring_base];
[ring_base]format=rgba,colorkey=black:0.01:0[ring_keyed];
[bg][ring_keyed]overlay=0:0[outv];
