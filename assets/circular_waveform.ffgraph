[1:a]showwaves=s=1200x80:mode=p2p:colors=white:scale=lin*8[wave_linear];
[wave_linear]format=gray[wave_src];
color=black@0:s=1200x1200,format=gray[blank];
[blank][wave_src]geq=lum='
r=sqrt((X-600)*(X-600)+(Y-555)*(Y-555));
rmin=240;
rmax=280;
a=(atan2(Y-555,X-600)+PI)/(2*PI);
sx=a*(W1-1);
sy=(r-rmin)/(rmax-rmin)*(H1-1);
between(r,rmin,rmax)*lum(sx,sy,1)
'[ring_raw];
[ring_raw]gblur=sigma=8[ring_glow];
[bg][ring_glow]overlay=0:0[outv]
