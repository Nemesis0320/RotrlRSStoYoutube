[0:v]scale=1200:1200,setsar=1[bg];
[1:a]showwaves=s=1200x80:mode=line:colors=white:scale=sqrt:draw=full[wave_small];
[wave_small]pad=1200:1200:0:560[wave_padded];
[wave_padded]format=gray[wave_gray];
[wave_gray]geq=lum='if(gt(lum(X,Y)*3,255),255,lum(X,Y)*3)'[amp_map];
[amp_map]geq=lum='between(sqrt((X-600)*(X-600)+(Y-555)*(Y-555)),260,280)*255 + between(sqrt((X-600)*(X-600)+(Y-555)*(Y-555)),240,300)*lum((atan2(Y-555,X-600)+PI)/(2*PI)*(W-1),H/2)'[polar_raw];
[polar_raw]format=rgba[wave_final];
[bg][wave_final]overlay=0:0[outv];
