[0:v]scale=1200:1200,setsar=1[bg];

[1:a]showwaves=s=1200x300:mode=p2p:colors=white:scale=sqrt[wave_raw];
[wave_raw]boxblur=2:0[wave_smooth];
[wave_smooth]v360=rect:polar:ih_fov=360:iv_fov=360[wave_polar];
[wave_polar]gblur=sigma=8[wave_glow];

[wave_glow]geq=lum='between(((X-600)*(X-600))/(222*222)+((Y-555)*(Y-555))/(260*260),1,1.1)*255'[wave_masked];

[bg][wave_masked]overlay=0:0[outv]
