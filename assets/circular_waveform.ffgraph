[0:v]scale=1200:1200,setsar=1[bg];
[1:a]showwaves=s=1200x200:mode=line:colors=white:scale=sqrt:draw=full,format=gray[wave_raw];
[wave_raw]boxblur=2:1[wave_blur];
[wave_blur]pad=1200:1200:0:(1200-ih)/2[wave_padded];
[wave_padded]geq=lum='between(sqrt((X-600)*(X-600)+(Y-555)*(Y-555)),260,280)*lum((atan2(Y-555,X-600)+PI)/(2*PI)*(W-1),600)'[ring_base];
[ring_base]geq=r='255':g='200':b='50':a='200'[gold_colored];
[gold_colored]boxblur=20:2[wave_final];
[bg][wave_final]overlay=0:0[outv];
